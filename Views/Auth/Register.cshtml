@using UniversityKitchen.Data.Enum
@model UniversityKitchen.Features.Auth.Dtos.RegisterDto

<header>
  <link rel="stylesheet" href="~/css/Register.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</header>

<!-- Section: Design Block -->
<section class="">
  <!-- Jumbotron -->
  <div class="px-4 py-5 px-md-5 text-center text-lg-start" style="background-color: hsl(0, 0%, 96%)">
    <div class="container">
      <div class="row gx-lg-5 align-items-center">
        <div class="col-lg-6 mb-5 mb-lg-0">
          <h1 class="my-5 display-3 fw-bold ls-tight">
            The best offer <br />
            <span class="text-primary">for your business</span>
          </h1>
          <p style="color: hsl(217, 10%, 50.8%)">
            Lorem ipsum dolor sit amet consectetur adipisicing elit.
            Eveniet, itaque accusantium odio, soluta, corrupti aliquam
            quibusdam tempora at cupiditate quis eum maiores libero
            veritatis? Dicta facilis sint aliquid ipsum atque?
          </p>
        </div>

        <div class="col-lg-6 mb-5 mb-lg-0">
          <div class="card">
            <div class="card-body py-5 px-md-5">
                <!-- 2 column grid layout with text inputs for the first and last names -->
                <div class="row">
                  <form asp-controller="Auth" asp-action="Register" method="post" class="col-md-6 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      <input asp-for="Firstname" type="text" id="form3Example1" class="form-control" />
                      <label asp-for="Firstname" class="form-label" for="form3Example1">First name</label>
                    </div>
                    <div data-mdb-input-init class="form-outline">
                      <input asp-for="Lastname" type="text" id="form3Example2" class="form-control" />
                      <label asp-for="Lastname" class="form-label" for="form3Example2">Last name</label>
                    </div>
                    <div data-mdb-input-init class="form-outline">
                      <input asp-for="Username" type="text" id="form3Example2" class="form-control" />
                      <label asp-for="Username" class="form-label" for="form3Example2">Username</label>
                    </div>
                    <div data-mdb-input-init class="form-outline">
                      <input asp-for="Password" type="text" id="form3Example2" class="form-control" />
                      <label asp-for="Password" class="form-label" for="form3Example2">Password</label>
                    </div>
                    <div data-mdb-input-init class="form-outline">
                      <input asp-for="PhoneNumber" type="text" id="form3Example2" class="form-control" value="+99890" />
                      <label asp-for="PhoneNumber" class="form-label" for="form3Example2">Phone Nummber</label>
                    </div>
                    <div class="col-12">
                      <label class="visually-hidden" for="inlineFormSelectPref">Select Role</label>
                      <select data-mdb-select-init class="form-select">
                        @foreach (var role in Model.Roles)
                        {
                          <option value="@role.Value">@(role.Text)</option>
                        }
                      </select>
                    </div>
                    <br/>
                    <br/>
                    
                    <button type="submit" data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-block mb-4">
                      Sign up
                    </button>
                  </form>
                </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Jumbotron -->
</section>
<!-- Section: Design Block -->