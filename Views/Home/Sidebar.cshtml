@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<div class="d-flex flex-column flex-shrink-0 p-3 text-white bg-dark sidebar">
    <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
        <span class="fs-4">Sidebar</span>
    </a>
    <hr>
    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item">
            <a asp-controller="Home" asp-action="Index"  class="nav-link @(currentController == "Home" ? "active" : "text-white")">
                Home
            </a>
        </li>
        <li>
            <a asp-controller="Dashboard" asp-action="Index"  class="nav-link @(currentController == "Dashboard" ? "active" : "text-white")">
                Dashboard
            </a>
        </li>
        <li>
            <a asp-controller="Orders" asp-action="Index" class="nav-link @(currentController == "Orders" ? "active" : "text-white")">
                Orders
            </a>
        </li>
        <li>
            <a asp-controller="Products" asp-action="Index" class="nav-link @(currentController == "Products" ? "active" : "text-white")">
                Products
            </a>
        </li>
        <li>
            <a asp-controller="Customers" asp-action="Index" class="nav-link @(currentController == "Customers" ? "active" : "text-white")">
                Customers
            </a>
        </li>
    </ul>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $(".nav-link").click(function (e) {
            e.preventDefault(); // Sahifa qayta yuklanishining oldini oladi

            var targetUrl = $(this).attr("href"); // URL ni olish
            $("#contentContainer").load(targetUrl); // Sahifani yuklash

            $(".nav-link").removeClass("active").addClass("text-white"); // Hammasidan active ni olib tashlash
            $(this).addClass("active").removeClass("text-white"); // Faqat bosilganga berish
        });
    });

</script>